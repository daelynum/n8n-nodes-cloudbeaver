{
    "name": "n8n-nodes-cloudbeaver",
    "version": "0.1.0",
    "description": "n8n node for CloudBeaver — execute SQL queries via CloudBeaver API",
    "license": "MIT",
    "homepage": "",
    "keywords": [
        "n8n-community-node-package",
        "n8n-community-node",
        "n8n",
        "cloudbeaver",
        "sql",
        "database"
    ],
    "author": {
        "name": "daelynum",
        "email": "vivanov89@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/daelynum/n8n-nodes-cloudbeaver.git"
    },
   "scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": false,
        "credentials": [
            "dist/credentials/CloudBeaverApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/CloudBeaver/CloudBeaver.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
